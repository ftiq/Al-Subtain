<odoo>
    <record id="view_calendar_appointment_form_inherit_product" model="ir.ui.view">
        <field name="name">calendar.appointment.form.product</field>
        <field name="model">calendar.appointment</field>
        <field name="inherit_id" ref="calendar.view_calendar_appointment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//sheet//group" position="inside">
                <field name="product_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="view_calendar_appointment_product_form" model="ir.ui.view">
        <field name="name">calendar.appointment.product.form</field>
        <field name="model">calendar.appointment.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_id"/>
                        <field name="appointment_type_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_calendar_appointment_product_tree" model="ir.ui.view">
        <field name="name">calendar.appointment.product.tree</field>
        <field name="model">calendar.appointment.product</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="product_id"/>
                <field name="appointment_type_id"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_calendar_appointment_product" 
              name="Appointment Services/Products"
              parent="calendar.menu_calendar_config"
              sequence="90"/>
    <act_window id="action_calendar_appointment_product"
        name="Appointment Products"
        res_model="calendar.appointment.product"
        view_mode="tree,form"
        menu_id="menu_calendar_appointment_product"/>
</odoo>
