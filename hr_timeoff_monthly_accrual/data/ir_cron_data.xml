<odoo>
  <!-- Monthly accrual -->
  <record id="ir_cron_accrue_timeoff" model="ir.cron">
    <field name="name">Monthly Timeoff Accrual</field>
    <!-- Updated to reference the community model_id record -->
    <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
    <field name="state">code</field>
    <field name="code">model._cron_accrue_timeoff()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">months</field>
    <field name="numbercall">-1</field>
    <field name="active">True</field>
    <field name="doall">False</field>
  </record>
  <!-- Annual allocation -->
  <record id="ir_cron_annual_alloc" model="ir.cron">
    <field name="name">Annual Timeoff Allocation</field>
    <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
    <field name="state">code</field>
    <field name="code">model._cron_annual_allocate()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">years</field>
    <field name="numbercall">-1</field>
    <field name="active">True</field>
    <field name="doall">False</field>
  </record>
</odoo>
