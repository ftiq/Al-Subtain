<odoo>
  <record id="view_hr_leave_type_accrual_settings" model="ir.ui.view">
    <field name="name">hr.leave.type.accrual.settings</field>
    <field name="model">hr.leave.type</field>
    <field name="inherit_id" ref="hr_holidays.view_hr_leave_type_form"/>
    <field name="arch" type="xml">
      <sheet position="inside">
        <group string="Accrual Settings">
          <field name="monthly_alloc_hours"/>
          <field name="threshold_hours"/>
          <field name="annual_alloc_hours"/>
          <field name="monthly_leave_days"/>
        </group>
      </sheet>
    </field>
  </record>
</odoo>
