<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- Demo Workflow: Legal Contract Review -->
    <record id="demo_process_legal_review" model="workflow.process">
      <field name="name">مراجعة عقد قانونياً</field>
      <field name="description">عملية موافقة ومراجعة للعقود الواردة</field>
      <field name="category">approval_workflow</field>
      <field name="process_type">sequential</field>
      <field name="expected_duration">72</field>
      <field name="escalation_threshold">96</field>
      <field name="priority">2</field>
      <field name="state">active</field>
      <field name="owner_id" ref="mgt_documents.demo_emp_manager"/>
      <field name="manager_ids" eval="[(6, 0, [ref('mgt_documents.demo_emp_manager'), ref('mgt_documents.demo_emp_director')])]"/>
      <field name="applicable_category_ids" eval="[(6, 0, [ref('mgt_documents.category_legal_contracts')])]"/>
    </record>

    <record id="demo_step_legal_receive" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_legal_review"/>
      <field name="name">استلام وتسجيل</field>
      <field name="sequence">10</field>
      <field name="step_type">manual</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_operations"/>
      <field name="estimated_hours">8</field>
    </record>

    <record id="demo_step_legal_review" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_legal_review"/>
      <field name="name">مراجعة قانونية</field>
      <field name="sequence">20</field>
      <field name="step_type">review</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_legal"/>
      <field name="requires_approval">True</field>
      <field name="estimated_hours">24</field>
    </record>

    <record id="demo_step_manager_approve" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_legal_review"/>
      <field name="name">اعتماد المدير</field>
      <field name="sequence">30</field>
      <field name="step_type">approval</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_management"/>
      <field name="estimated_hours">8</field>
    </record>

    <record id="demo_step_archive" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_legal_review"/>
      <field name="name">أرشفة</field>
      <field name="sequence">40</field>
      <field name="step_type">notification</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_archive"/>
      <field name="estimated_hours">4</field>
    </record>

    <!-- Link steps after all steps are created to avoid forward refs -->
    <record id="demo_step_legal_receive" model="workflow.step">
      <field name="next_step_ids" eval="[(6, 0, [ref('mgt_documents.demo_step_legal_review')])]"/>
    </record>
    <record id="demo_step_legal_review" model="workflow.step">
      <field name="next_step_ids" eval="[(6, 0, [ref('mgt_documents.demo_step_manager_approve')])]"/>
    </record>
    <record id="demo_step_manager_approve" model="workflow.step">
      <field name="next_step_ids" eval="[(6, 0, [ref('mgt_documents.demo_step_archive')])]"/>
    </record>

    <!-- Demo Workflow: Internal Memo Review -->
    <record id="demo_process_internal_memo" model="workflow.process">
      <field name="name">مراجعة مذكرة داخلية</field>
      <field name="description">عملية مراجعة واعتماد للمذكرات الداخلية</field>
      <field name="category">document_review</field>
      <field name="process_type">sequential</field>
      <field name="expected_duration">24</field>
      <field name="escalation_threshold">36</field>
      <field name="priority">1</field>
      <field name="state">active</field>
      <field name="owner_id" ref="mgt_documents.demo_emp_supervisor"/>
      <field name="manager_ids" eval="[(6, 0, [ref('mgt_documents.demo_emp_manager')])]"/>
      <field name="applicable_category_ids" eval="[(6, 0, [ref('mgt_documents.category_memos')])]"/>
    </record>

    <record id="demo_step_memo_review" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_internal_memo"/>
      <field name="name">مراجعة المشرف</field>
      <field name="sequence">10</field>
      <field name="step_type">review</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_management"/>
      <field name="estimated_hours">6</field>
    </record>

    <record id="demo_step_memo_director_approve" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_internal_memo"/>
      <field name="name">اعتماد المدير العام</field>
      <field name="sequence">20</field>
      <field name="step_type">approval</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_management"/>
      <field name="estimated_hours">4</field>
    </record>

    <record id="demo_step_memo_archive" model="workflow.step">
      <field name="process_id" ref="mgt_documents.demo_process_internal_memo"/>
      <field name="name">أرشفة</field>
      <field name="sequence">30</field>
      <field name="step_type">notification</field>
      <field name="responsible_type">department</field>
      <field name="responsible_department_id" ref="mgt_documents.demo_dept_archive"/>
      <field name="estimated_hours">2</field>
    </record>

    <!-- Link memo steps after creation -->
    <record id="demo_step_memo_review" model="workflow.step">
      <field name="next_step_ids" eval="[(6, 0, [ref('mgt_documents.demo_step_memo_director_approve')])]"/>
    </record>
    <record id="demo_step_memo_director_approve" model="workflow.step">
      <field name="next_step_ids" eval="[(6, 0, [ref('mgt_documents.demo_step_memo_archive')])]"/>
    </record>

    <!-- Routing Rules -->
    <record id="demo_router_contracts_legal" model="document.router">
      <field name="name">توجيه العقود إلى القانوني</field>
      <field name="description">عند وجود وثيقة عقد واردة، ابدأ عملية مراجعة قانونية</field>
      <field name="sequence">10</field>
      <field name="priority">2</field>
      <field name="state">active</field>
      <field name="active">True</field>
      <field name="filter_document_type">contract</field>
      <field name="applicable_category_ids" eval="[(6, 0, [ref('mgt_documents.category_legal_contracts')])]"/>
      <field name="applicable_department_ids" eval="[(6, 0, [ref('mgt_documents.demo_dept_legal')])]"/>
      <field name="target_process_id" ref="mgt_documents.demo_process_legal_review"/>
      <field name="notification_message">تم توجيه الوثيقة لبدء مراجعة قانونية</field>
    </record>

    <record id="demo_router_memo_internal" model="document.router">
      <field name="name">توجيه المذكرات الداخلية</field>
      <field name="description">المذكرات الداخلية تمر بمراجعة المشرف ثم اعتماد المدير العام</field>
      <field name="sequence">20</field>
      <field name="priority">1</field>
      <field name="state">active</field>
      <field name="active">True</field>
      <field name="filter_document_type">memo</field>
      <field name="applicable_category_ids" eval="[(6, 0, [ref('mgt_documents.category_memos')])]"/>
      <field name="applicable_department_ids" eval="[(6, 0, [ref('mgt_documents.demo_dept_management')])]"/>
      <field name="target_process_id" ref="mgt_documents.demo_process_internal_memo"/>
      <field name="notification_message">تم توجيه المذكرة لبدء المراجعة</field>
    </record>

  </data>
</odoo>
