<odoo>
  <record id="email_template_internal_mail" model="mail.template">
    <field name="name">Internal Mail Notification</field>
    <field name="model_id" ref="model_internal_mail"/>
    <field name="email_from">${(user.email_formatted or '')|safe}</field>
    <field name="subject">مراسلة داخلية: ${object.name}</field>
    <field name="partner_to">${','.join(object.recipient_ids.mapped('email'))}</field>
    <field name="body_html"><![CDATA[
      <p>عزيزي/عزيزتي ${object.recipient_ids.name},</p>
      <p>لديك مراسلة جديدة برقم <strong>${object.name}</strong>.</p>
      <p>الرجاء الاطلاع عليها والموافقة أو طلب التعديل.</p>
      <p>
        <a href="${object.get_portal_url()}/approve">الموافقة</a> |
        <a href="${object.get_portal_url()}/modify">طلب تعديل</a>
      </p>
    ]]></field>
  </record>
</odoo>
