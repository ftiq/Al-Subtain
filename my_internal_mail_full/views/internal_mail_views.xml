<odoo>
  <record id="view_internal_mail_form" model="ir.ui.view">
    <field name="name">internal.mail.form</field>
    <field name="model">internal.mail</field>
    <field name="arch" type="xml">
      <form string="مراسلة داخلية">
        <sheet>
          <group>
            <field name="name"/>
            <field name="date"/>
            <field name="sender_id"/>
            <field name="recipient_ids" widget="many2many_tags"/>
          </group>
          <notebook>
            <page string="المرفقات">
              <field name="attachment_ids" widget="many2many_binary"/>
            </page>
            <page string="التتبع">
              <field name="message_follower_ids" widget="mail_followers"/>
              <field name="message_ids" widget="mail_thread"/>
            </page>
          </notebook>
          <footer>
            <button name="action_send_email" string="أرسل عبر الإيميل" type="object" class="btn-primary"/>
            <button name="action_send_whatsapp" string="أرسل عبر واتساب" type="object" class="btn-secondary"/>
            <button name="action_approve" string="موافقة" type="object" states="sent" class="btn-success"/>
            <button name="action_modify" string="طلب تعديل" type="object" states="sent" class="btn-warning"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,sent,approved,modified"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_internal_mail_tree" model="ir.ui.view">
    <field name="name">internal.mail.tree</field>
    <field name="model">internal.mail</field>
    <field name="arch" type="xml">
      <tree string="مراسلات داخلية">
        <field name="name"/>
        <field name="date"/>
        <field name="sender_id"/>
        <field name="state"/>
      </tree>
    </field>
  </record>
</odoo>
